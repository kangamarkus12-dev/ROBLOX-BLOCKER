<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center"
    android:background="#0D0D1A">
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Configuration"
        android:textSize="28sp"
        android:textColor="#25F4EE"
        android:textStyle="bold"
        android:layout_marginBottom="24dp" />
    <EditText
        android:id="@+id/password_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:inputType="numberPassword"
        android:maxLength="8"
        android:background="#1A1A2E"
        android:padding="12dp"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:hint="Code secret (6-8 chiffres)"
        android:textColorHint="#666666"
        android:layout_marginBottom="12dp" />
    <Button
        android:id="@+id/btn_save_password"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Sauvegarder le code"
        android:background="#25F4EE"
        android:textColor="#000000"
        android:layout_marginBottom="16dp" />
    <Button
        android:id="@+id/btn_enable_admin"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Activer la protection"
        android:background="#FF6B6B"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="12dp" />
    <Button
        android:id="@+id/btn_enable_accessibility"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Activer l'Accessibilite"
        android:background="#FFA500"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="12dp" />
    <Button
        android:id="@+id/btn_start_service"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Activer le blocage"
        android:background="#4CAF50"
        android:textColor="#FFFFFF" />
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="L'application n'a pas d'icone."
        android:textColor="#888888"
        android:textSize="12sp"
        android:layout_marginTop="20dp"
        android:gravity="center" />
</LinearLayout>
